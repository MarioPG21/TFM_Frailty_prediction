# =============================================================================
# TFM_Frailty_prediction — variables de configuración del entorno local
# =============================================================================
# Copia este fichero como .env y rellena los valores antes de levantar el
# entorno. El fichero .env NUNCA se sube a control de versiones.
#
# Uso:
#   cp .env.example .env
#   # editar .env con los valores reales
#   docker compose up -d
# =============================================================================


# -----------------------------------------------------------------------------
# MinIO
# -----------------------------------------------------------------------------
# Credenciales de acceso a MinIO. En AWS estas variables apuntarán a las
# credenciales del rol IAM; el código no cambia, solo estas variables.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# Endpoint interno (usado por Spark, MLflow y Airflow dentro de Docker).
# En AWS se deja vacío: el SDK de AWS resuelve S3 nativo sin endpoint explícito.
MINIO_ENDPOINT=http://minio:9000

# Buckets que se crean automáticamente al arrancar minio-init.
# Modificar solo si se cambia la arquitectura de capas Medallion.
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_SILVER=silver
MINIO_BUCKET_GOLD=gold
MINIO_BUCKET_MLFLOW=mlflow


# -----------------------------------------------------------------------------
# Spark — cluster standalone (master + 2 workers)
# -----------------------------------------------------------------------------
# RAM que cada worker ofrece al cluster. El mem_limit del contenedor Docker
# se establece en este valor + ~512 MB de overhead de JVM (ver compose).
# Con 2 workers a 2G cada uno, los jobs disponen de hasta 4G de RAM de Spark.
# No subir por encima de 2G por worker en un entorno de 16 GB RAM.
SPARK_WORKER_MEMORY=2G

# Núcleos de CPU que cada worker ofrece al cluster.
# Con 2 workers a 2 cores cada uno = 4 cores disponibles para jobs Spark.
SPARK_WORKER_CORES=2

# Credenciales S3A que Spark usa para conectarse a MinIO/S3.
# Deben coincidir con MINIO_ROOT_USER / MINIO_ROOT_PASSWORD.
# En AWS se sustituyen por las credenciales del rol IAM.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123


# -----------------------------------------------------------------------------
# Kafka — broker KRaft
# -----------------------------------------------------------------------------
# UUID fijo del cluster Kafka. Se genera una sola vez y NO debe cambiarse
# después del primer arranque: si cambia, el storage queda inválido y se
# pierden todos los topics y offsets acumulados.
#
# Para generar uno nuevo (solo si se arranca desde cero):
#   docker run --rm apache/kafka:4.0.0 /opt/kafka/bin/kafka-storage.sh random-uuid
KAFKA_CLUSTER_UUID=MkU3OEVBNTcwNTJENDM2Qg

# Topic donde se publican los eventos de zancada de la Fuente C.
KAFKA_TOPIC_GAIT=gait-events


# -----------------------------------------------------------------------------
# Airflow — orquestador del pipeline (solo entorno local)
# -----------------------------------------------------------------------------
# UID del usuario Linux que ejecuta Airflow. En Linux debe coincidir con el
# UID del usuario actual para que los ficheros montados en volúmenes tengan
# los permisos correctos.
#
# Obtenerlo con:   id -u
# Añadirlo al .env con:   echo "AIRFLOW_UID=$(id -u)" >> .env
AIRFLOW_UID=50000

# Credenciales del usuario administrador de la interfaz web de Airflow.
AIRFLOW_WWW_USER=airflow
AIRFLOW_WWW_PASSWORD=airflow

# Clave de cifrado Fernet para las credenciales almacenadas en la base de
# datos de Airflow (conexiones, variables sensibles). DEBE generarse antes
# del primer arranque y no cambiarse después (invalidaría los secretos
# almacenados).
#
# Generar con:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=


# -----------------------------------------------------------------------------
# MLflow — tracking y model registry
# -----------------------------------------------------------------------------
# URI del servidor de tracking. Dentro de Docker los contenedores lo
# referencian por nombre de servicio. En AWS apuntará al servidor MLflow
# desplegado o a un endpoint externo.
MLFLOW_TRACKING_URI=http://mlflow:5000

# Endpoint S3 que MLflow usa para guardar artefactos (modelos, métricas).
# En local apunta a MinIO. En AWS se deja vacío (S3 nativo).
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# Nombre del experimento por defecto. Se crea automáticamente si no existe.
MLFLOW_EXPERIMENT_NAME=frailty-estimation
